<h1><%= @place["name"] %></h1>

<% if current_user.present? %>
  <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-outline-dark mb-4">New Post</a>
<% end %>

<% if @entries.length > 0 %>
  <div class="row row-cols-1 row-cols-md-3 g-4">
    <% @entries.each do |entry| %>
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= entry["title"] %></h5>
            <p class="text-muted small"><%= entry["occurred_on"] %></p>
            <p class="card-text"><%= entry["description"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No entries yet.</p>
<% end %>

<p><a href="/places">Back to all places</a></p>