<h1>New Post for <%= @place["name"] %></h1>

<form action="/entries" method="post" enctype="multipart/form-data">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
  <input type="hidden" name="place_id" value="<%= @place["id"] %>">

  <div class="mb-3">
    <label>Title</label>
    <input type="text" name="title" class="form-control">
  </div>

  <div class="mb-3">
    <label>Date</label>
    <input type="date" name="occurred_on" class="form-control">
  </div>

  <div class="mb-3">
    <label>Description</label>
    <textarea name="description" class="form-control" rows="5"></textarea>
  </div>

  <div class="mb-3">
    <label for="uploaded_image_input" class="form-label">Upload Image</label>
    <input type="file" name="uploaded_image" id="uploaded_image_input" class="form-control" accept="image/png, image/jpg, image/jpeg, image/gif">
  </div>

  <button type="submit" class="btn btn-primary">Save Entry</button>
  <a href="/places/<%= @place["id"] %>" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>